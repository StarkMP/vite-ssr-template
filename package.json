{
  "name": "vite-ssr-template",
  "private": true,
  "version": "1.0.0",
  "author": "StarkMP <starkmp.work@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "node --eval \"fs.rmSync('dist',{recursive:true,force:true})\" && npm run build:client && npm run build:server && npm run build:node",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:node": "tsup",
    "preview": "node dist/node/server.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/middie": "^9.3.1",
    "@fastify/static": "^9.1.0",
    "beasties": "^0.4.2",
    "fastify": "^5.8.4",
    "html-minifier-terser": "^7.2.0",
    "lru-cache": "^11.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-compression": "^0.5.1"
  }
}
